{
  "color": {
    "$type": "color",
    "action": {
      "primary": {
        "default":  { "$value": "{primary.500}" },
        "hover":    { "$value": "{primary.400}" },
        "pressed":  { "$value": "{primary.600}" },
        "focus":    { "$value": "{primary.500}" },
        "disabled": { "$value": "{neutral.300}" }
      },
      "secondary": {
        "default":  { "$value": "{secondary.500}" },
        "hover":    { "$value": "{secondary.400}" },
        "pressed":  { "$value": "{secondary.600}" },
        "focus":    { "$value": "{secondary.500}" },
        "disabled": { "$value": "{neutral.300}" },
        "bg":       { "$value": "{secondary.100}" },
        "border":   { "$value": "{secondary.300}" }
      },
      "destructive": {
        "default":  { "$value": "{danger.500}" },
        "hover":    { "$value": "{danger.600}" },
        "pressed":  { "$value": "{danger.700}" },
        "focus":    { "$value": "{danger.500}" },
        "disabled": { "$value": "{neutral.300}" }
      },
      "ghost": {
        "hover-bg":   { "$value": "{neutral.100}" },
        "pressed-bg": { "$value": "{neutral.200}" }
      }
    },
    "surface": {
      "base":    { "$value": "{white}" },
      "subtle":  { "$value": "{neutral.50}" },
      "raised":  { "$value": "{white}" },
      "overlay": { "$value": "{neutral.900}" }
    },
    "text": {
      "primary":   { "$value": "{neutral.950}" },
      "secondary": { "$value": "{neutral.600}" },
      "disabled":  { "$value": "{neutral.400}" },
      "inverse":   { "$value": "{white}" },
      "on-action": { "$value": "{white}" }
    },
    "border": {
      "default": { "$value": "{neutral.300}" },
      "subtle":  { "$value": "{neutral.200}" },
      "strong":  { "$value": "{neutral.500}" },
      "focus":   { "$value": "{primary.500}" }
    },
    "feedback": {
      "success": {
        "default":  { "$value": "{success.500}" },
        "subtle":   { "$value": "{success.50}" },
        "emphasis": { "$value": "{success.700}" },
        "bg":       { "$value": "{success.100}" },
        "border":   { "$value": "{success.200}" }
      },
      "warning": {
        "default":  { "$value": "{warning.500}" },
        "subtle":   { "$value": "{warning.50}" },
        "emphasis": { "$value": "{warning.700}" },
        "bg":       { "$value": "{warning.100}" },
        "border":   { "$value": "{warning.200}" }
      },
      "danger": {
        "default":  { "$value": "{danger.500}" },
        "subtle":   { "$value": "{danger.50}" },
        "emphasis": { "$value": "{danger.700}" },
        "bg":       { "$value": "{danger.100}" },
        "border":   { "$value": "{danger.200}" }
      },
      "info": {
        "default":  { "$value": "{info.500}" },
        "subtle":   { "$value": "{info.50}" },
        "emphasis": { "$value": "{info.700}" },
        "bg":       { "$value": "{info.100}" },
        "border":   { "$value": "{info.200}" }
      }
    }
  }
}
