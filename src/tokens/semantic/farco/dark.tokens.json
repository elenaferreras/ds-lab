{
  "color": {
    "$type": "color",
    "action": {
      "primary": {
        "default":  { "$value": "{primary.400}" },
        "hover":    { "$value": "{primary.300}" },
        "pressed":  { "$value": "{primary.500}" },
        "focus":    { "$value": "{primary.400}" },
        "disabled": { "$value": "{neutral.700}" }
      },
      "secondary": {
        "default":  { "$value": "{secondary.400}" },
        "hover":    { "$value": "{secondary.300}" },
        "pressed":  { "$value": "{secondary.500}" },
        "focus":    { "$value": "{secondary.400}" },
        "disabled": { "$value": "{neutral.700}" },
        "bg":       { "$value": "{secondary.950}" },
        "border":   { "$value": "{secondary.800}" }
      },
      "destructive": {
        "default":  { "$value": "{danger.400}" },
        "hover":    { "$value": "{danger.300}" },
        "pressed":  { "$value": "{danger.200}" },
        "focus":    { "$value": "{danger.400}" },
        "disabled": { "$value": "{neutral.700}" }
      },
      "ghost": {
        "hover-bg":   { "$value": "{neutral.800}" },
        "pressed-bg": { "$value": "{neutral.700}" }
      }
    },
    "surface": {
      "base":    { "$value": "{neutral.950}" },
      "subtle":  { "$value": "{neutral.900}" },
      "raised":  { "$value": "{neutral.800}" },
      "overlay": { "$value": "{black}" }
    },
    "text": {
      "primary":   { "$value": "{neutral.50}" },
      "secondary": { "$value": "{neutral.400}" },
      "disabled":  { "$value": "{neutral.600}" },
      "inverse":   { "$value": "{neutral.950}" },
      "on-action": { "$value": "{black}" }
    },
    "border": {
      "default": { "$value": "{neutral.200}" },
      "subtle":  { "$value": "{neutral.800}" },
      "strong":  { "$value": "{white}" },
      "focus":   { "$value": "{primary.400}" }
    },
    "feedback": {
      "success": {
        "default":  { "$value": "{success.400}" },
        "subtle":   { "$value": "{success.900}" },
        "emphasis": { "$value": "{success.300}" },
        "bg":       { "$value": "{success.950}" },
        "border":   { "$value": "{success.800}" }
      },
      "warning": {
        "default":  { "$value": "{warning.400}" },
        "subtle":   { "$value": "{warning.900}" },
        "emphasis": { "$value": "{warning.300}" },
        "bg":       { "$value": "{warning.950}" },
        "border":   { "$value": "{warning.800}" }
      },
      "danger": {
        "default":  { "$value": "{danger.400}" },
        "subtle":   { "$value": "{danger.900}" },
        "emphasis": { "$value": "{danger.300}" },
        "bg":       { "$value": "{danger.950}" },
        "border":   { "$value": "{danger.800}" }
      },
      "info": {
        "default":  { "$value": "{info.400}" },
        "subtle":   { "$value": "{info.900}" },
        "emphasis": { "$value": "{info.300}" },
        "bg":       { "$value": "{info.950}" },
        "border":   { "$value": "{info.800}" }
      }
    }
  }
}
