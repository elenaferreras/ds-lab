{
  "font-family": {
    "$type": "fontFamily",
    "base": { "$value": ["Overused Grotesk", "sans-serif"] }
  },
  "font-size": {
    "$type": "dimension",
    "xs": { "$value": "12px" },
    "sm": { "$value": "14px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "20px" },
    "xl": { "$value": "24px" }
  },
  "font-weight": {
    "$type": "fontWeight",
    "regular": { "$value": 400 },
    "medium":  { "$value": 500 },
    "bold":    { "$value": 700 }
  },
  "line-height": {
    "$type": "number",
    "tight":   { "$value": 1.2 },
    "base":    { "$value": 1.5 },
    "relaxed": { "$value": 1.75 }
  },
  "letter-spacing": {
    "$type": "dimension",
    "tight": { "$value": "-0.01em" },
    "base":  { "$value": "0.01em" }
  }
}
