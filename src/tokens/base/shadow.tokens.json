{
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "offsetX": "0",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0",
        "color": "#0000000d"
      }
    },
    "md": {
      "$value": {
        "offsetX": "0",
        "offsetY": "4px",
        "blur": "8px",
        "spread": "0",
        "color": "#0000001a"
      }
    },
    "lg": {
      "$value": {
        "offsetX": "0",
        "offsetY": "8px",
        "blur": "24px",
        "spread": "0",
        "color": "#0000001f"
      }
    }
  }
}
